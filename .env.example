# Pacemaker v4.0 — переменные окружения для деплоя
# Скопируй в .env (не коммитить!) или настрой на Railway/Render через UI

# === ОБЯЗАТЕЛЬНЫЕ ===

# Database URL. Локально — sqlite (можно не задавать, дефолт planner.db в рабочей папке)
# На Railway — задаётся автоматически переменной DATABASE_URL из Postgres addon
# DATABASE_URL=sqlite:///planner.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === ОПЦИОНАЛЬНЫЕ ===

# Flask secret_key — генерится автоматически при первом старте если не задан
# FLASK_SECRET_KEY=your-strong-random-string-min-32-chars

# Путь к sqlite БД (только если SQLite, не Postgres)
# PACEMAKER_DB=/data/planner.db

# Порт (Railway/Render задают сами через $PORT)
# PORT=5000

# Режим отладки (только для разработки!)
# FLASK_DEBUG=0
